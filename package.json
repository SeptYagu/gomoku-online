{
  "name": "gomoku-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/online-server.ts --dev",
    "dev:next": "next dev",
    "dev:online": "tsx src/server/online-server.ts --dev",
    "build": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "tsx src/server/online-server.ts",
    "start:next": "next start",
    "start:online": "tsx src/server/online-server.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "arena": "tsx tools/engine-arena.ts",
    "opening-book": "tsx tools/generate-opening-book.ts",
    "smoke:share-url": "tsx tools/smoke-share-url.ts",
    "smoke:lobby": "tsx tools/smoke-lobby.ts",
    "smoke:lobby-ui": "tsx tools/smoke-lobby-ui.ts",
    "smoke:online-room": "tsx tools/smoke-online-room.ts",
    "smoke:public-chat": "tsx tools/smoke-public-chat.ts",
    "smoke:room-chat": "tsx tools/smoke-room-chat.ts",
    "verify:online": "tsx tools/verify-online-server.ts"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.15"
  }
}
